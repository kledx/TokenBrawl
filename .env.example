# Arena Server config
ARENA_PORT=3001

# Frontend WebSocket URL (injected at build time via GitHub Actions secret: VITE_ARENA_WS_URL)
# For local dev only — production value is set in GitHub repo Secrets
VITE_ARENA_WS_URL=ws://localhost/arena

# Nginx exposed port (default 80)
WEB_PORT=80

# ─── LLM Configuration (for Bot Agents) ─────────────────────
# Required when running the 'bots' service in docker-compose.
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, Groq, Ollama, etc.)
# If not set, bots will fall back to the built-in rules engine.
ARENA_LLM_BASE_URL=https://api.openai.com
ARENA_LLM_API_KEY=your-api-key-here
ARENA_LLM_MODEL=gpt-4o-mini

# Examples:
# DeepSeek:  ARENA_LLM_BASE_URL=https://api.deepseek.com  ARENA_LLM_MODEL=deepseek-chat
# Groq:      ARENA_LLM_BASE_URL=https://api.groq.com/openai  ARENA_LLM_MODEL=llama-3.3-70b-versatile
# Ollama:    ARENA_LLM_BASE_URL=http://localhost:11434  ARENA_LLM_MODEL=qwen2.5:7b
# SiliconFlow: ARENA_LLM_BASE_URL=https://api.siliconflow.cn  ARENA_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─── Image overrides (optional) ─────────────────────────────
# By default docker-compose pulls :latest from ghcr.io.
# Override here to pin a specific SHA or tag:
# ARENA_IMAGE=ghcr.io/YOUR_GITHUB_ORG/YOUR_REPO/arena:abc1234
# WEB_IMAGE=ghcr.io/YOUR_GITHUB_ORG/YOUR_REPO/web:abc1234
